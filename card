<!DOCTYPE html>
<html lang="en"> 
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="description" content="TAPDconnex public profile card.">
<title>Profile — TAPDconnex</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #F6F2EA; --bg-paper: #F2EDE2; --surface: #FFFFFF; --surface-warm: #FBF8F2;
    --text-primary: #181410; --text-secondary: #5C5247; --text-muted: #95887A; --text-faint: #C2B7A8;
    --border-soft: #EAE2D2; --border-medium: #D9CDB6;
    --accent: #1E4F5C; --accent-hover: #14404C; --accent-bg: #E8EFEF;
    --warm-accent: #B8501E; --warm-bg: #FBEDD9;
    --success: #2D6A4F; --success-bg: #DCEFE3;
    --space-2: 8px; --space-3: 12px; --space-4: 16px; --space-5: 20px; --space-6: 24px; --space-7: 32px; --space-8: 40px;
    --radius-md: 10px; --radius-lg: 14px; --radius-xl: 20px; --radius-pill: 999px;
    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'Manrope', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --shadow-md: 0 2px 8px rgba(24,20,16,0.06); --shadow-lg: 0 8px 24px rgba(24,20,16,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--bg); color: var(--text-primary); font-family: var(--font-body); font-size: 16px; line-height: 1.5; -webkit-font-smoothing: antialiased; min-height: 100vh; }
  body { background-image: radial-gradient(circle at 12% 0%, rgba(30,79,92,0.04) 0%, transparent 42%), radial-gradient(circle at 88% 100%, rgba(184,80,30,0.03) 0%, transparent 42%); background-attachment: fixed; }

  /* Visitor preview banner */
  .preview-banner {
    position: sticky; top: 0; z-index: 60; display: none;
    background: var(--text-primary); color: var(--bg);
    padding: 10px var(--space-5); font-size: 13px;
    display: none; align-items: center; justify-content: space-between; gap: 12px;
  }
  .preview-banner.show { display: flex; }
  .preview-banner .pb-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; }
  .preview-banner .pb-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--warm-bg); }
  .preview-banner a { color: var(--bg); font-weight: 600; text-decoration: none; border-bottom: 1px solid rgba(246,242,234,0.5); white-space: nowrap; }

  .wrap { max-width: 560px; margin: 0 auto; padding: var(--space-6) var(--space-5) var(--space-8); }

  .card {
    background: var(--surface); border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); overflow: hidden;
  }
  .card-hero {
    background: linear-gradient(160deg, var(--accent) 0%, #163e48 100%);
    padding: var(--space-8) var(--space-6) var(--space-7); color: #fff; position: relative; text-align: center;
  }
  .avatar {
    width: 96px; height: 96px; border-radius: 50%; margin: 0 auto var(--space-4);
    background: rgba(255,255,255,0.14); border: 2px solid rgba(255,255,255,0.4);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 36px; font-weight: 600; color: #fff;
    background-size: cover; background-position: center;
  }
  .card-name { font-family: var(--font-display); font-size: 27px; font-weight: 600; letter-spacing: -0.01em; }
  .card-role { font-size: 15px; color: rgba(255,255,255,0.85); margin-top: 5px; }
  .card-intro { font-family: var(--font-display); font-style: italic; font-size: 16px; color: rgba(255,255,255,0.92); margin-top: var(--space-4); line-height: 1.5; }

  .card-body { padding: var(--space-6); }
  .blk { margin-bottom: var(--space-6); }
  .blk:last-child { margin-bottom: 0; }
  .blk-h { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 10px; }
  .blk-p { font-size: 15px; color: var(--text-secondary); line-height: 1.6; }

  .relate-list { display: flex; flex-direction: column; gap: 8px; }
  .relate {
    display: flex; gap: 10px; align-items: flex-start; font-size: 14.5px; color: var(--text-primary);
    background: var(--surface-warm); border: 1px solid var(--border-soft); border-radius: var(--radius-md);
    padding: 12px 14px; line-height: 1.5;
  }
  .relate .tick { color: var(--accent); flex-shrink: 0; font-weight: 700; }

  .ways { display: flex; flex-wrap: wrap; gap: 8px; }
  .way { font-size: 13.5px; font-weight: 600; color: var(--accent); background: var(--accent-bg); padding: 7px 12px; border-radius: var(--radius-pill); }

  .links { display: flex; flex-direction: column; gap: 10px; }
  .link-row {
    display: flex; align-items: center; gap: 12px; text-decoration: none;
    border: 1px solid var(--border-soft); border-radius: var(--radius-md); padding: 12px 14px;
    color: var(--text-primary); font-weight: 600; font-size: 14px; transition: border-color 0.15s ease;
  }
  .link-row:hover { border-color: var(--accent); }
  .link-row .lr-k { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); margin-left: auto; }

  .cta-bar { padding: 0 var(--space-6) var(--space-6); }
  .cta {
    display: flex; align-items: center; justify-content: center; gap: 9px; width: 100%;
    background: var(--accent); color: #fff; border: none; border-radius: var(--radius-md);
    padding: 16px; font-family: var(--font-body); font-size: 16px; font-weight: 700; cursor: pointer;
    text-decoration: none; min-height: 56px; transition: background 0.15s ease;
  }
  .cta:hover { background: var(--accent-hover); }
  .cta.wa { background: #25D366; color: #07301a; }
  .cta.wa:hover { background: #1faa52; }

  .foot { text-align: center; margin-top: var(--space-6); font-size: 12px; color: var(--text-muted); }
  .foot a { color: var(--text-secondary); text-decoration: none; border-bottom: 1px solid var(--border-medium); }

  .empty-state { text-align: center; padding: var(--space-8) var(--space-5); }
  .empty-state h1 { font-family: var(--font-display); font-size: 26px; font-weight: 500; margin-bottom: 12px; }
  .empty-state p { color: var(--text-secondary); line-height: 1.6; margin-bottom: var(--space-6); }
  .empty-state a { display: inline-flex; background: var(--accent); color: #fff; text-decoration: none; padding: 13px 22px; border-radius: var(--radius-md); font-weight: 600; }

  .powered { display: inline-flex; align-items: center; gap: 7px; justify-content: center; margin-top: 6px; }
  .powered .pm { width: 18px; height: 18px; border-radius: 5px; background: var(--accent); color: #fff; font-family: var(--font-display); font-size: 10px; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; }
</style>
</head>
<body>

<div class="preview-banner" id="previewBanner">
  <span class="pb-label"><span class="pb-dot"></span> Visitor preview mode</span>
  <span style="font-size:12.5px;opacity:0.85;flex:1;min-width:0;">This is exactly what people see when they tap your NFC card or scan your QR.</span>
  <a id="exitPreview" href="profile.html">Back to editing</a>
</div>

<div class="wrap" id="wrap"></div>

<script>
const STORAGE_KEY = 'tapd_onboarding_data';
function readProfile() {
  try { const p = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null'); return (p && p.data) ? p.data : null; }
  catch (e) { return null; }
}
function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function initialsOf(name){ return (name||'?').split(/\s+/).filter(Boolean).map(w=>w[0]).slice(0,2).join('').toUpperCase() || '?'; }
function isPreview(){ try { return new URLSearchParams(location.search).get('preview') === '1'; } catch(e){ return false; } }

function digits(s){ return String(s||'').replace(/[^0-9]/g,''); }

function renderCard() {
  const d = readProfile();
  const wrap = document.getElementById('wrap');

  if (isPreview()) document.getElementById('previewBanner').classList.add('show');

  if (!d || !d.name) {
    wrap.innerHTML = `
      <div class="empty-state">
        <h1>No profile yet</h1>
        <p>Once you set up your TAPDconnex profile, this is the page people will see when they tap your card.</p>
        <a href="profile.html">Set up my profile &rarr;</a>
      </div>`;
    return;
  }

  const initials = initialsOf(d.name);
  const roleLine = [d.role, d.company].filter(Boolean).join(' · ');
  const pains = (d.painPoints || []).filter(p => p && p.trim());
  const ways = []
    .concat(Array.isArray(d.waysToWork) ? d.waysToWork : [d.waysToWork])
    .filter(w => w && String(w).trim())
    // allow comma-separated single field to render as chips
    .flatMap(w => String(w).split(/\s*[,;]\s*/)).filter(Boolean);

  // links
  const links = [];
  if (d.linkedin)  links.push({ k:'LinkedIn',  label: d.linkedin.replace(/^https?:\/\//,''), href: d.linkedin.startsWith('http')?d.linkedin:'https://'+d.linkedin });
  if (d.website)   links.push({ k:'Website',   label: d.website.replace(/^https?:\/\//,''),  href: d.website.startsWith('http')?d.website:'https://'+d.website });
  if (d.instagram) links.push({ k:'Instagram', label: d.instagram, href: 'https://instagram.com/'+d.instagram.replace(/^@/,'') });
  if (d.email)     links.push({ k:'Email',     label: d.email, href: 'mailto:'+d.email });

  // primary CTA from preferred channel
  let cta = '';
  if (d.preferredChannel === 'whatsapp' && digits(d.whatsapp)) {
    cta = `<a class="cta wa" href="https://wa.me/${digits(d.whatsapp)}">Continue on WhatsApp</a>`;
  } else if (d.preferredChannel === 'email' && d.email) {
    cta = `<a class="cta" href="mailto:${esc(d.email)}">Email ${esc((d.name||'').split(' ')[0])}</a>`;
  } else if (d.preferredChannel === 'linkedin' && d.linkedin) {
    cta = `<a class="cta" href="${esc(d.linkedin.startsWith('http')?d.linkedin:'https://'+d.linkedin)}">Connect on LinkedIn</a>`;
  } else if (links[0]) {
    cta = `<a class="cta" href="${esc(links[0].href)}">Get in touch</a>`;
  }

  wrap.innerHTML = `
    <div class="card">
      <div class="card-hero">
        <div class="avatar" ${d.photo ? `style="background-image:url(${esc(d.photo)})"` : ''}>${d.photo ? '' : esc(initials)}</div>
        <div class="card-name">${esc(d.name)}</div>
        ${roleLine ? `<div class="card-role">${esc(roleLine)}</div>` : ''}
        ${d.intro ? `<div class="card-intro">${esc(d.intro)}</div>` : ''}
      </div>
      <div class="card-body">
        ${d.whatYouDo ? `<div class="blk"><div class="blk-h">What I do</div><div class="blk-p">${esc(d.whatYouDo)}</div></div>` : ''}
        ${pains.length ? `<div class="blk"><div class="blk-h">Can you relate to this?</div><div class="relate-list">${pains.map(p=>`<div class="relate"><span class="tick">&#10003;</span><span>${esc(p)}</span></div>`).join('')}</div></div>` : ''}
        ${ways.length ? `<div class="blk"><div class="blk-h">Ways we could work together</div><div class="ways">${ways.map(w=>`<span class="way">${esc(w)}</span>`).join('')}</div></div>` : ''}
        ${links.length ? `<div class="blk"><div class="blk-h">Find me</div><div class="links">${links.map(l=>`<a class="link-row" href="${esc(l.href)}" target="_blank" rel="noopener">${esc(l.label)}<span class="lr-k">${esc(l.k)}</span></a>`).join('')}</div></div>` : ''}
      </div>
      ${cta ? `<div class="cta-bar">${cta}</div>` : ''}
    </div>
    <div class="foot">
      <div class="powered"><span class="pm">T</span> Powered by TAPDconnex</div>
    </div>
  `;
}
renderCard();
</script>
</body>
</html>
