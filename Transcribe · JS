// ============================================================
// POST /api/transcribe
// Accepts an audio file (multipart/form-data, field name "audio")
// Returns: { transcript: string, provider, model }
//
// Provider switch (per the MVP architecture):
//   TRANSCRIPTION_PROVIDER = 'openai' (default) | 'groq'
// Both use the OpenAI-compatible transcription API, so swapping is config-only.
// ============================================================

import { createReadStream } from 'node:fs';
import formidable from 'formidable';
import OpenAI from 'openai';

// Vercel: disable the default body parser so we can read multipart uploads.
export const config = { api: { bodyParser: false } };

function getTranscriptionClient() {
  const provider = (process.env.TRANSCRIPTION_PROVIDER || 'openai').toLowerCase();
  if (provider === 'groq') {
    return {
      provider,
      model: process.env.GROQ_TRANSCRIBE_MODEL || 'whisper-large-v3',
      client: new OpenAI({
        apiKey: process.env.GROQ_API_KEY,
        baseURL: 'https://api.groq.com/openai/v1'
      })
    };
  }
  return {
    provider: 'openai',
    model: process.env.OPENAI_TRANSCRIBE_MODEL || 'whisper-1',
    client: new OpenAI({ apiKey: process.env.OPENAI_API_KEY })
  };
}

function parseForm(req) {
  const form = formidable({ maxFileSize: 30 * 1024 * 1024 }); // 30MB ceiling
  return new Promise((resolve, reject) => {
    form.parse(req, (err, fields, files) => {
      if (err) return reject(err);
      resolve({ fields, files });
    });
  });
}

export default async function handler(req, res) {
  if (req.method !== 'POST') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  const { provider, model, client } = getTranscriptionClient();
  if (!client.apiKey) {
    // No key configured yet — tell the frontend to use its local fallback.
    return res.status(200).json({ status: 'placeholder', message: 'Transcription key not configured.' });
  }

  try {
    const { files } = await parseForm(req);
    const audio = files.audio?.[0] || files.audio;
    if (!audio) return res.status(400).json({ error: 'No audio file provided (field "audio").' });

    const filepath = audio.filepath || audio.path;
    const result = await client.audio.transcriptions.create({
      file: createReadStream(filepath),
      model,
      // language hint optional: response is plain text by default
    });

    return res.status(200).json({
      transcript: result.text || '',
      provider,
      model
    });
  } catch (err) {
    console.error('[transcribe] error:', err);
    return res.status(500).json({ error: 'Transcription failed', detail: String(err.message || err) });
  }
}
